DATABASE_URL="file:./complaints.db"
PORT=3001
CORS_ORIGIN="http://localhost:3000"
JWT_SECRET="change-me"
JWT_EXPIRES_IN="1d"

# Supabase Storage (S3-compatible). Leave keys blank to disable uploads.
S3_ENDPOINT="https://<project-ref>.supabase.co/storage/v1/s3"
# Must match the project's region exactly (Dashboard > Storage > S3 Connection).
S3_REGION="ap-northeast-1"
S3_BUCKET="complaint-attachments"
# Generate at: Supabase Dashboard > Project Settings > Storage > S3 Access Keys
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_FORCE_PATH_STYLE="true"
# Set only for a public bucket:
# https://<project-ref>.supabase.co/storage/v1/object/public/complaint-attachments
S3_PUBLIC_URL=""

# LINE Messaging API. Leave token blank to disable notifications.
LINE_CHANNEL_ACCESS_TOKEN=""
LINE_TARGET_ID=""
# Channel secret — verifies the POST /api/line/webhook signature.
# Leave blank to skip verification (local/dev only).
LINE_CHANNEL_SECRET=""
